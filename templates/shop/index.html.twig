{% extends 'base.html.twig' %}
{% block title %}Shop | NovaWear{% endblock %}

{% block body %}
<div class="container py-4">

  {# Breadcrumb #}
  <nav class="mb-3" style="font-size:.82rem;color:#888;">
    <a href="{{ path('home') }}" class="text-muted text-decoration-none">Home</a>
    <span class="mx-1">/</span>
    <span class="text-dark fw-semibold">Shop</span>
  </nav>

  <div class="row g-4">

    {# ════════════════════════════════════════════
       SIDEBAR FILTRES
    ════════════════════════════════════════════ #}
    <div class="col-lg-3" id="shopSidebar">

      {# Prix #}
      <div class="mb-4">
        <p class="text-uppercase fw-bold mb-3" style="font-size:.7rem;letter-spacing:.12em;">Filter by price</p>
        <div id="priceSliderTrack" class="position-relative mb-3"
             style="height:4px;background:#e0e0e0;border-radius:2px;margin:0 8px;">
          <div id="priceSliderRange"
               style="position:absolute;height:100%;background:#111;border-radius:2px;"></div>
          <input type="range" id="sliderMin" class="nw-range-input" min="0"
                 max="{{ priceRange.max|round }}" value="{{ filters.min_price ?? 0 }}" step="1">
          <input type="range" id="sliderMax" class="nw-range-input" min="0"
                 max="{{ priceRange.max|round }}" value="{{ filters.max_price ?? priceRange.max|round }}" step="1">
        </div>
        <div class="d-flex align-items-center justify-content-between">
          <span class="small text-muted">
            Price: $<span id="priceMinLabel">{{ filters.min_price ?? 0 }}</span>
            — $<span id="priceMaxLabel">{{ filters.max_price ?? priceRange.max|round }}</span>
          </span>
          <button class="btn btn-dark btn-sm px-3" id="priceFilterBtn"
                  style="font-size:.72rem;letter-spacing:.06em;">FILTER</button>
        </div>
      </div>

      <hr class="my-3">

      {# Couleurs #}
      <div class="mb-4">
        <p class="text-uppercase fw-bold mb-3" style="font-size:.7rem;letter-spacing:.12em;">Filter by color</p>
        <div class="d-flex flex-column gap-1">
          {% for color in colors %}
            <label class="d-flex align-items-center justify-content-between gap-2 py-1 px-1 rounded"
                   style="cursor:pointer;font-size:.875rem;"
                   onmouseover="this.style.background='#f5f5f5'" onmouseout="this.style.background=''">
              <div class="d-flex align-items-center gap-2">
                <input type="checkbox" class="js-filter-color d-none"
                       name="colors[]" value="{{ color.id }}"
                       {# Ligne 56 — couleurs #}
                        {{ filters.colors is defined and (color.id ~ '') in filters.colors ? 'checked' : '' }}
                <span class="nw-color-dot js-color-dot {{ filters.colors is defined and (color.id ~ '') in filters.colors ? 'nw-color-dot--checked' : '' }}"
                      style="background:{{ color.hexCode }};"></span>
                <span>{{ color.name }}</span>
              </div>
              <span class="badge bg-light text-dark border" style="font-size:.7rem;">
                {{ color.productColorVariants|length }}
              </span>
            </label>
          {% endfor %}
        </div>
      </div>

      <hr class="my-3">

      {# Tailles #}
      <div class="mb-4">
        <p class="text-uppercase fw-bold mb-3" style="font-size:.7rem;letter-spacing:.12em;">Filter by size</p>
        <div class="d-flex flex-column gap-1">
          {% for size in sizes %}
            <label class="d-flex align-items-center justify-content-between gap-2 py-1 px-1 rounded"
                   style="cursor:pointer;font-size:.875rem;"
                   onmouseover="this.style.background='#f5f5f5'" onmouseout="this.style.background=''">
              <div class="d-flex align-items-center gap-2">
                <input type="checkbox" class="js-filter-size"
                       name="sizes[]" value="{{ size.id }}"
                       {{ filters.sizes is defined and (size.id ~ '') in filters.sizes ? 'checked' : '' }}>
                <span>{{ size.label }}</span>
              </div>
              <span class="badge bg-light text-dark border" style="font-size:.7rem;">
                {{ size.cartItems|length }}
              </span>
            </label>
          {% endfor %}
        </div>
      </div>

      <hr class="my-3">

      {# Marques #}
      <div class="mb-4">
        <p class="text-uppercase fw-bold mb-3" style="font-size:.7rem;letter-spacing:.12em;">Filter by brand</p>
        <div class="input-group input-group-sm mb-3">
          <input type="text" class="form-control border-end-0" placeholder="Find a Brand"
                 id="brandSearch" style="font-size:.82rem;">
          <span class="input-group-text bg-white border-start-0">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
              <path d="M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" stroke="#777" stroke-width="2"/>
              <path d="M16.5 16.5 21 21" stroke="#777" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </div>
        <div class="d-flex flex-column gap-1" id="brandList">
          {% for brand in brands %}
            <label class="d-flex align-items-center gap-2 py-1 px-1 rounded js-brand-item"
                   data-name="{{ brand.name|lower }}"
                   style="cursor:pointer;font-size:.875rem;"
                   onmouseover="this.style.background='#f5f5f5'" onmouseout="this.style.background=''">
              <input type="radio" class="js-filter-brand" name="brand" value="{{ brand.id }}"
                     {{ filters.brand is defined and filters.brand == (brand.id ~ '') ? 'checked' : '' }}>
              <span>{{ brand.name }}</span>
            </label>
          {% endfor %}
        </div>
      </div>

      <hr class="my-3">

      {# Statut produit #}
      <div class="mb-4">
        <p class="text-uppercase fw-bold mb-3" style="font-size:.7rem;letter-spacing:.12em;">Product status</p>
        <div class="d-flex flex-column gap-2">
          <label class="d-flex align-items-center gap-2" style="cursor:pointer;font-size:.875rem;">
            <input type="checkbox" class="form-check-input js-filter-status m-0"
                   id="filterOnSale" name="on_sale" value="1"
                   {{ filters.on_sale ? 'checked' : '' }}>
            On sale
          </label>
          <label class="d-flex align-items-center gap-2" style="cursor:pointer;font-size:.875rem;">
            <input type="checkbox" class="form-check-input js-filter-status m-0"
                   id="filterInStock" name="in_stock" value="1"
                   {{ filters.in_stock ? 'checked' : '' }}>
            In stock
          </label>
        </div>
      </div>

    </div>{# /sidebar #}

    {# ════════════════════════════════════════════
       GRILLE PRODUITS
    ════════════════════════════════════════════ #}
    <div class="col-lg-9">

      {# Toolbar #}
      <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <span class="text-muted small" id="productCount">
          {{ products|length }} product{{ products|length != 1 ? 's' : '' }}
        </span>
        <div class="d-flex align-items-center gap-2">
          <label class="small text-muted mb-0">Sort by</label>
          <select class="form-select form-select-sm border-0 bg-light" id="sortSelect" style="font-size:.82rem;min-width:160px;">
            <option value="newest"      {{ filters.sort == 'newest'     ? 'selected' : '' }}>Newest</option>
            <option value="popularity"  {{ filters.sort == 'popularity'  ? 'selected' : '' }}>Popularity</option>
            <option value="rating"      {{ filters.sort == 'rating'      ? 'selected' : '' }}>Average rating</option>
            <option value="price_asc"   {{ filters.sort == 'price_asc'   ? 'selected' : '' }}>Price: low to high</option>
            <option value="price_desc"  {{ filters.sort == 'price_desc'  ? 'selected' : '' }}>Price: high to low</option>
          </select>
        </div>
      </div>

      {# Grille #}
      <div id="productsGrid">
        {% include 'shop/_products_grid.html.twig' with {products: products} %}
      </div>

    </div>{# /col-lg-9 #}
  </div>{# /row #}
</div>
{% endblock %}