{% extends 'base.html.twig' %}

{% block title %}My Account | NovaWear{% endblock %}

{% block body %}

{# ══════════════════════════════════════════════════════════════
   HERO BANNER
   ══════════════════════════════════════════════════════════════ #}
<div class="ac-hero position-relative overflow-hidden">
  <div class="ac-hero__overlay"></div>
  <div class="container position-relative z-1 py-5 text-center text-white">
    <h1 class="ac-hero__title fw-bold mb-2">My Account</h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item">
          <a href="{{ path('home') }}" class="text-white text-opacity-75 text-decoration-none">Home</a>
        </li>
        <li class="breadcrumb-item active text-white" aria-current="page">My Account</li>
      </ol>
    </nav>
  </div>
</div>

{# ══════════════════════════════════════════════════════════════
   CORPS — Sidebar (gauche) + Contenu (droite)
   ══════════════════════════════════════════════════════════════ #}
<div class="bg-white py-5">
  <div class="container">
    <div class="row g-4 align-items-start">

      {# ════════════════════════════════════════════════════════
         SIDEBAR — Navigation
         ════════════════════════════════════════════════════════ #}
      <div class="col-lg-3">

        <p class="ac-sidebar-title mb-3">MY ACCOUNT</p>

        <nav class="ac-sidebar-nav">
        
          <a href="{{ path('account.dashboard') }}"
             class="ac-nav-item {% if app.request.attributes.get('_route') == 'account.dashboard' %}ac-nav-item--active{% endif %}">
            Dashboard
          </a>
          <a href="{{ path('account.orders') }}"
             class="ac-nav-item {% if app.request.attributes.get('_route') == 'account.orders' %}ac-nav-item--active{% endif %}">
            Orders
          </a>
          <a href="{{ path('account.addresses') }}"
             class="ac-nav-item {% if app.request.attributes.get('_route') == 'account.addresses' %}ac-nav-item--active{% endif %}">
            Addresses
          </a>
          <a href="{{ path('account.details') }}"
             class="ac-nav-item {% if app.request.attributes.get('_route') == 'account.details' %}ac-nav-item--active{% endif %}">
            Account details
          </a>
          <a href="{{ path('account.wishlist') }}"
             class="ac-nav-item {% if app.request.attributes.get('_route') == 'account.wishlist' %}ac-nav-item--active{% endif %}">
            Wishlist
          </a>
          <a href="{{ path('app_logout') }}" class="ac-nav-item ac-nav-item--logout">
            Logout
          </a>
        </nav>
      </div>

      {# ════════════════════════════════════════════════════════
         CONTENU PRINCIPAL
         ════════════════════════════════════════════════════════ #}
      <div class="col-lg-9">

        {# Salutation ─────────────────────────────────────────── #}
        <p class="small mb-3" style="color:#555">
          Hello <strong class="text-dark">{{ app.user.username }}</strong>
          (not {{ app.user.username }}?
          <a href="{{ path('app_logout') }}" class="text-dark fw-semibold">Log out</a>)
        </p>

        <p class="small text-muted mb-4" style="line-height:1.7">
          From your account dashboard you can view your
          <a href="{{ path('account.orders') }}" class="text-dark fw-semibold text-decoration-none">recent orders</a>,
          manage your
          <a href="{{ path('account.addresses') }}" class="text-dark fw-semibold text-decoration-none">shipping and billing addresses</a>,
          and
          <a href="{{ path('account.details') }}" class="text-dark fw-semibold text-decoration-none">edit your password and account details</a>.
        </p>

        {# Grille de cards ────────────────────────────────────── #}
        <div class="row g-3">

          {# Orders #}
          <div class="col-sm-6 col-xl-4">
            <a href="{{ path('account.orders') }}" class="ac-dash-card">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
                <rect x="9" y="3" width="6" height="4" rx="1"/>
                <line x1="9" y1="12" x2="15" y2="12"/>
                <line x1="9" y1="16" x2="13" y2="16"/>
              </svg>
              <span>Orders</span>
            </a>
          </div>

          {# Addresses #}
          <div class="col-sm-6 col-xl-4">
            <a href="{{ path('account.addresses') }}" class="ac-dash-card">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>Addresses</span>
            </a>
          </div>

          {# Account details #}
          <div class="col-sm-6 col-xl-4">
            <a href="{{ path('account.details') }}" class="ac-dash-card">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <span>Account details</span>
            </a>
          </div>

          {# Wishlist #}
          <div class="col-sm-6 col-xl-4">
            <a href="{{ path('account.wishlist') }}" class="ac-dash-card">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
              </svg>
              <span>Wishlist</span>
            </a>
          </div>

          {# Logout #}
          <div class="col-sm-6 col-xl-4">
            <a href="{{ path('app_logout') }}" class="ac-dash-card ac-dash-card--logout">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
                <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
              </svg>
              <span>Logout</span>
            </a>
          </div>

        </div>{# /row cards #}

      </div>{# /col-lg-9 #}
    </div>{# /row #}
  </div>{# /container #}
</div>

{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    /* ── Hero ───────────────────────────────────────────────── */
    .ac-hero {
      background: url('{{ asset('images/account-hero.jpg') }}') center/cover no-repeat;
      min-height: 200px;
    }
    .ac-hero__overlay {
      position: absolute; inset: 0;
      background: rgba(0,0,0,.45);
    }
    .ac-hero__title {
      font-size: clamp(2rem, 5vw, 3.5rem);
      letter-spacing: -1px;
    }
    .breadcrumb-item + .breadcrumb-item::before {
      color: rgba(255,255,255,.6);
      content: '/';
    }

    /* ── Sidebar ────────────────────────────────────────────── */
    .ac-sidebar-title {
      font-size: .7rem;
      font-weight: 800;
      letter-spacing: 1.5px;
      color: #111;
    }
    .ac-sidebar-nav {
      display: flex;
      flex-direction: column;
    }
    .ac-nav-item {
      display: block;
      padding: 10px 16px;
      font-size: .875rem;
      color: #333;
      text-decoration: none;
      border-left: 3px solid transparent;
      transition: background .15s, border-color .15s, color .15s;
    }
    .ac-nav-item:hover {
      background: #f7f7f7;
      color: #111;
    }
    .ac-nav-item--active {
      background: #f0f0f0;
      border-left-color: #111;
      font-weight: 700;
      color: #111;
    }
    .ac-nav-item--logout { color: #e63e3e; }
    .ac-nav-item--logout:hover { background: #fff5f5; color: #c93333; }

    /* ── Dashboard cards ────────────────────────────────────── */
    .ac-dash-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding: 36px 20px;
      border: 1px solid #e8e8e8;
      border-radius: 4px;
      text-decoration: none;
      color: #aaa;
      transition: border-color .2s, color .2s, box-shadow .2s, transform .15s;
    }
    .ac-dash-card svg {
      width: 44px; height: 44px;
      stroke: #bbb;
      transition: stroke .2s;
    }
    .ac-dash-card span {
      font-size: .82rem;
      font-weight: 600;
      color: #555;
      letter-spacing: .2px;
      transition: color .2s;
    }
    .ac-dash-card:hover {
      border-color: #111;
      box-shadow: 0 4px 16px rgba(0,0,0,.07);
      transform: translateY(-2px);
      color: #111;
    }
    .ac-dash-card:hover svg  { stroke: #111; }
    .ac-dash-card:hover span { color: #111; }

    /* Logout card — rouge au hover */
    .ac-dash-card--logout:hover {
      border-color: #e63e3e;
    }
    .ac-dash-card--logout:hover svg  { stroke: #e63e3e; }
    .ac-dash-card--logout:hover span { color: #e63e3e; }
  </style>
{% endblock %}