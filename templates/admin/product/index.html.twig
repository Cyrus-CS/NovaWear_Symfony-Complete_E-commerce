{% extends 'admin/base.html.twig' %}

{% block title %}Product index{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="card shadow-sm border-0 p-5">
        {# Header du tableau, inspiré de la maquette #}
        <div class="card-header bg-white border-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h4 mb-1">Products</h1>
                    <p class="text-muted small mb-0">
                        Total products : <strong>{{ products|length }}</strong>
                    </p>
                </div>

                <div class="d-flex gap-2">
                    {# On garde ta route et le texte "Create new" #}
                    <a href="{{ path('app_product_new') }}" class="btn btn-primary">
                        + Create new
                    </a>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Description</th>
                        <th scope="col">Price</th>
                        <th scope="col">Compare</th>
                        <th scope="col">Stock</th>
                        <th scope="col">Active</th>
                     {# <th scope="col">Updated at</th>#}
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for product in products %}
                    <tr>

                        <td class="fw-semibold">
                            {{ product.name }}
                        </td>

                        <td class="text-truncate" style="max-width: 220px;">
                            {{ product.description | split(' ') | slice(0, 2) | join(' ') ~ '...'  ?? product.description }}
                        </td>

                        <td>
                            {{ product.price|number_format(2, '.', ' ') }} €
                        </td>

                        <td>
                            {% if product.compareAtPrice %}
                                <span class="text-danger text-decoration-line-through">
                                    {{ product.compareAtPrice|number_format(2, '.', ' ') }} €
                                </span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>

                        <td>{{ product.stock }}</td>
                        {#  
                        <td>
                            {% if product.ratingAverage is not null %}
                                {{ product.ratingAverage|number_format(1, '.', ' ') }}
                            {% endif %}
                        </td>#}

                        {# Booléens affichés avec des switches Bootstrap (désactivés en lecture seule) #}
                        <td>
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" disabled
                                       {% if product.isActive %}checked{% endif %}>
                            </div>
                        </td>
                        {#  Date de création et de mise à jour, formatées pour être lisibles 
                         {
                        <td class="text-muted small">
                            {{ product.createdAt ? product.createdAt|date('d M Y H:i') : '' }}
                        </td>#}

                        {#  <td class="text-muted small">
                            {{ product.updatedAt ? product.updatedAt|date('d M Y H:i') : '' }}
                        </td>#}

                        <td class="text-end">
                            <a href="{{ path('app_product_show', {'id': product.id}) }}"
                               class="btn btn-md btn-outline-secondary">
                                show
                            </a>
                            <a href="{{ path('app_product_edit', {'id': product.id}) }}"
                               class="btn btn-md btn-primary ms-1">
                                edit
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="16" class="text-center text-muted py-4">
                            no records found
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {#   Pagination à ajouter ici si besoin #}
    <div class="card-footer bg-white border-0 d-flex justify-content-end">
        {# Exemple de pagination Bootstrap #}
    </div>
</div>
{% endblock %}