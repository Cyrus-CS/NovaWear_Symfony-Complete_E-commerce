  {# ── LIGHTBOX / CARROUSEL PLEIN ÉCRAN ── #}
  <div id="imageLightbox" class="nw-lightbox d-none">
    <div class="nw-lightbox-backdrop"></div>

    <div class="nw-lightbox-inner">
      <button type="button" class="nw-lightbox-close" aria-label="Fermer">&times;</button>
      <button type="button" class="nw-lightbox-prev" aria-label="Image précédente">&#10094;</button>

      <img id="lightboxImage" src="" alt="{{ product.name }}">

      <button type="button" class="nw-lightbox-next" aria-label="Image suivante">&#10095;</button>

      <div class="nw-lightbox-counter">
        <span id="lightboxCurrent">1</span> / <span id="lightboxTotal">{{ product.productImages|length }}</span>
      </div>
    </div>
  </div>

  {# Données pour le carrousel plein écran (JSON) #}
  {% set galleryUrls = [] %}
  {% for image in product.productImages %}
      {% set galleryUrls = galleryUrls|merge([asset('uploads/images/products/' ~ image.path)]) %}
  {% endfor %}

  <script id="productGalleryData" type="application/json">
    {{ galleryUrls|json_encode|raw }}
  </script>

  {# Variantes par couleur : pour l’instant on met les mêmes valeurs que le produit.
  Quand tu auras une vraie entité de variation, tu rempliras avec les vrais prix/stock/tailles. #}
  <script id="colorVariantsData" type="application/json">
  {
    {% for color in product.colors %}
      "{{ color.id }}": {
        "price": {{ product.price }},
        "compareAtPrice": {{ product.compareAtPrice is not null ? product.compareAtPrice : 'null' }},
        "stock": {{ product.stock }},
        "sizeIds": [
          {% for size in product.sizes %}
            {{ size.id }}{% if not loop.last %}, {% endif %}
          {% endfor %}
        ]
      }{% if not loop.last %},{% endif %}
    {% endfor %}
  }
  </script>

  <script>
    // Données de base du produit (sans couleur sélectionnée)
    window.baseProductData = {
      price: {{ product.price }},
      compareAtPrice: {{ product.compareAtPrice is not null ? product.compareAtPrice : 'null' }},
      stock: {{ product.stock }},
      sizeIds: [
        {% for size in product.sizes %}
          {{ size.id }}{% if not loop.last %}, {% endif %}
        {% endfor %}
      ]
    };
  </script>

</div>


{# Modal — seulement si connecté #}
{% if app.user %}
{# MODAL: Write a Review (inchangé, juste adapter les noms de champs à ton entité Review si besoin) #}
<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold" id="reviewModalLabel" style="font-family:var(--nw-font-display);font-size:20px;">
          Write a Review
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body pt-3">
        <form id="reviewForm" action="{{ path('review_store', {id: product.id}) }}" method="POST" novalidate>
          <input type="hidden" name="_token" value="{{ csrf_token('review_' ~ product.id) }}" />
          <input type="hidden" name="product_id" value="{{ product.id }}" />

          {# Rating étoile #}
          <div class="mb-4">
            <label class="form-label text-muted small mb-2">Your Rating</label>
            <div class="nw-star-rate flex-row-reverse justify-content-end" id="starRating">
              {% for i in 5..1 %}
                <input type="radio" name="rating" id="star{{ i }}" value="{{ i }}" {% if i == 5 %}required{% endif %} />
                <label for="star{{ i }}" title="{{ i }} star{{ i > 1 ? 's' : '' }}">★</label>
              {% endfor %}
            </div>
          </div>

          {# Nom #}
          <div class="mb-3">
            <label for="reviewAuthor" class="form-label fw-semibold" style="font-size:14px;">Your Name</label>
            <input
              type="text" id="reviewAuthor" name="author_name"
              class="form-control rounded-3"
              placeholder="e.g. Samantha D."
              required minlength="2"
              style="height:48px;border-color:var(--nw-line);"
            />
          </div>

          {# Commentaire #}
          <div class="mb-4">
            <label for="reviewComment" class="form-label fw-semibold" style="font-size:14px;">Your Review</label>
            <textarea
              id="reviewComment" name="comment"
              class="form-control rounded-3"
              rows="4"
              placeholder="Share your experience with this product…"
              required minlength="10"
              style="border-color:var(--nw-line);resize:none;"
            ></textarea>
          </div>

          <button type="submit" class="nw-btn nw-btn-primary w-100" style="height:50px;font-size:15px;">
            Submit Review
          </button>
        </form>
      </div>

    </div>
  </div>
</div>
{% endif %}
{# ══════════════════════════════════════════════════════════════
   REVIEW FORM — Soumission AJAX + injection card dans #reviewGrid
   À placer juste avant {% endblock %} dans show.html.twig
   ══════════════════════════════════════════════════════════════ #}
<script>
(function () {
  'use strict';

  const form     = document.getElementById('reviewForm');
  const modal    = document.getElementById('reviewModal');
  const grid     = document.getElementById('reviewGrid');
  const emptyMsg = grid ? grid.querySelector('.col-12 .text-muted') : null;

  if (!form) return;

  /* ── Rendu étoiles ─────────────────────────────────────────── */
  function renderStars(rating) {
    let html = '<span class="nw-stars" style="font-size:14px;">';
    for (let i = 1; i <= 5; i++) {
      html += `<span${i > rating ? ' class="nw-star-dim"' : ''}>★</span>`;
    }
    html += '</span>';
    return html;
  }

  /* ── Création du HTML d'une review card ────────────────────── */
  function buildReviewCard(review) {
    return `
      <div class="col review-item" style="opacity:0;transform:translateY(10px);transition:opacity .35s ease,transform .35s ease">
        <article class="nw-reviewcard h-100">
          <div class="d-flex justify-content-between align-items-start mb-2">
            ${renderStars(review.rating)}
            <button class="nw-kebab" aria-label="Options">···</button>
          </div>
          <div class="d-flex align-items-center gap-2 mb-2">
            <strong style="font-size:14px;">${escHtml(review.authorName)}</strong>
            ${review.isVerified ? '<span class="nw-verified" title="Verified purchase">✓</span>' : ''}
          </div>
          <p class="nw-review-text mb-2">"${escHtml(review.comment)}"</p>
          <div class="nw-review-date">Posted on ${review.createdAt}</div>
        </article>
      </div>`;
  }

  /* ── Échappement HTML minimal ──────────────────────────────── */
  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  /* ── Affichage d'une erreur dans le formulaire ─────────────── */
  function showFormError(msg) {
    let alert = form.querySelector('.review-alert');
    if (!alert) {
      alert = document.createElement('div');
      alert.className = 'review-alert alert alert-danger py-2 small mb-3 rounded-3';
      form.prepend(alert);
    }
    alert.textContent = msg;
    alert.style.display = 'block';
  }

  function clearFormError() {
    const alert = form.querySelector('.review-alert');
    if (alert) alert.style.display = 'none';
  }

  /* ── Soumission AJAX ───────────────────────────────────────── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearFormError();

    const submitBtn = form.querySelector('[type="submit"]');
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting…';

    try {
      const res  = await fetch(form.action, {
        method:  'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body:    new FormData(form),
      });

      const data = await res.json();

      if (!res.ok || data.errors) {
        const msg = data.errors ? data.errors.join(' ') : (data.error || 'An error occurred.');
        showFormError(msg);
        return;
      }

      // ── Succès : injecter la card dans #reviewGrid ─────────
      if (grid) {
        // Retirer le message "Be the first to review" si présent
        const placeholder = grid.querySelector('.col-12');
        if (placeholder && placeholder.querySelector('.text-muted')) {
          placeholder.remove();
        }

        // Insérer la nouvelle card en tête de grille
        grid.insertAdjacentHTML('afterbegin', buildReviewCard(data.review));

        // Animer l'apparition
        const newCard = grid.firstElementChild;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            newCard.style.opacity   = '1';
            newCard.style.transform = 'translateY(0)';
          });
        });
      }

      // ── Fermer le modal Bootstrap ──────────────────────────
      const bsModal = bootstrap.Modal.getInstance(modal);
      if (bsModal) bsModal.hide();

      // ── Réinitialiser le formulaire ────────────────────────
      form.reset();

      // Réinitialiser les étoiles visuellement (radio Bootstrap)
      form.querySelectorAll('.nw-star-rate input[type="radio"]')
        .forEach(r => r.checked = false);

      // Basculer vers l'onglet Reviews si pas déjà actif
      const reviewTab = document.querySelector('[data-tab="reviews"]');
      if (reviewTab && !reviewTab.classList.contains('active')) {
        reviewTab.click();
      }

    } catch (err) {
      showFormError('Network error. Please try again.');
      console.error(err);
    } finally {
      submitBtn.disabled    = false;
      submitBtn.textContent = originalText;
    }
  });

})();
</script>

{% endblock %}