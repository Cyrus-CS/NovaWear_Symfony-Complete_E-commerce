{# templates/admin/product/new.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block title %}New Product{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-1">Create new Product</h1>
                    <p class="text-muted small mb-0">
                        Fill in the product information and then click “Save.”
                    </p>
                </div>
                {# On garde ta route et l’idée du lien "back to list" #}
                <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary">
                    back to list
                </a>
            </div>

            {{ include('admin/product/_form.html.twig', { button_label: 'Enregistrer le produit' }) }}

        </div>
    </div>
</div>
{% endblock %}