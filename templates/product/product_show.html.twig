{% extends 'base.html.twig' %}

{% block title %} {{ product.name }} | NovaWear{% endblock %}
{% block body_class 'page-product-show' %}
{% block body %}
<div class="container py-5">
  <section class="row g-4 align-items-start mb-5">

    {# ── GALERIE ── #}
    <div class="col-lg-6">
      <div class="d-flex gap-3">

        {# Colonne de vignettes #}
        <div class="nw-thumb-col">
          {% for image in product.productImages %}
          {% set src = asset('uploads/images/products/' ~ image.path) %}
          <button
            type="button"
            class="nw-thumb js-product-thumb {% if loop.first %}is-active{% endif %}"
            data-src="{{ src }}"
            data-color-id="{{ image.color ? image.color.id : '' }}"
            data-is-main="{{ image.isMain ? '1' : '0' }}"
          >
            <img src="{{ src }}" alt="{{ product.name }}" loading="lazy">
          </button>
        {% endfor %}

        {# Bouton "+X plus", géré par le JS selon le groupe (produit / couleur) #}
        <button type="button" class="nw-thumb js-product-thumb-more d-none">
          <div class="nw-thumb-more-wrapper">
            <img
              src=""
              alt="{{ product.name }}"
              loading="lazy"
              class="js-more-thumb-img"
            >
            <div class="nw-thumb-more-overlay">
              <span class="nw-thumb-more-icon">
                <img src="{{ asset('images/icons/gallery.svg') }}" alt="Plus">
              </span>
              <span class="nw-thumb-more-count js-more-thumb-count"></span>
            </div>
          </div>
        </button>
        </div>

        {# Image principale #}
        <div class="nw-mainimg flex-grow-1 js-main-zoom">
          {% set main = product.mainImage %}

          {% if main %}
            {% set mainSrc = asset('uploads/images/products/' ~ main.path) %}
            <img
              id="mainProductImage"
              src="{{ mainSrc }}"
              alt="{{ product.name }}"
              data-default-src="{{ mainSrc }}"
              data-color-id="{{ main.color ? main.color.id : '' }}"
              data-is-main="{{ main.isMain ? '1' : '0' }}"
            >
          {% else %}
            <img
              id="mainProductImage"
              src="{{ asset('images/placeholders/product-placeholder.jpg') }}"
              alt="{{ product.name }}"
              data-default-src="{{ asset('images/placeholders/product-placeholder.jpg') }}"
            >
          {% endif %}
        </div>
      </div>
    </div>

    {# ── INFO ── #}
    <div class="col-lg-6">

      <h1 class="nw-product-title">{{ product.name }}</h1>

      {# Rating #}
      {% set avg = product.ratingAverage is not null ? product.ratingAverage : 0 %}
      <div class="d-flex align-items-center gap-2 mb-2">
        <span class="nw-stars">
          {% set full = avg|round(0, 'floor') %}
          {% for i in 1..5 %}
            <span {% if i > full %}class="nw-star-dim"{% endif %}>★</span>
          {% endfor %}
        </span>
        <small class="text-muted">
          {{ avg }}/5
          {% if product.ratingCount is defined %}
            ({{ product.ratingCount }} review{{ product.ratingCount > 1 ? 's' : '' }})
          {% endif %}
        </small>
      </div>

      {# Prix #}
      <div class="d-flex align-items-center gap-3 mb-3">
      <span
        class="nw-price-now js-product-price"
        data-base-price="{{ product.price }}"
      >
        ${{ product.price }}
      </span>

      <span
        class="nw-price-old js-product-compare-at {{ product.compareAtPrice ? '' : 'd-none' }}"
      >
        {% if product.compareAtPrice %}
          ${{ product.compareAtPrice }}
        {% endif %}
      </span>

      <span
        class="nw-badge-sale js-discount-badge {{ product.compareAtPrice ? '' : 'd-none' }}"
      >
        {% if product.compareAtPrice %}
          {# remise initiale pour le produit global #}
          {% set discount = ((product.compareAtPrice - product.price) / product.compareAtPrice * 100)|round %}
          -{{ discount }}%
        {% endif %}
      </span>
    </div>

      <p class="nw-desc">{{ product.description | nl2br }}</p>

      {# Couleurs #}
      {% if product.colors|length > 0 %}
        <div class="mb-3">
            <div class="nw-opt-label">
              Color:
              <span id="selectedColorName"></span>
            </div>

            <div class="d-flex align-items-center gap-2 flex-wrap" id="colorSwatches">

              {# 1) Swatch pour l'image principale du produit #}
              {% set main = product.mainImage %}
              {% if main %}
                {% set mainSrc = asset('uploads/images/products/' ~ main.path) %}
              {% else %}
                {% set mainSrc = asset('images/placeholders/product-placeholder.jpg') %}
              {% endif %}

              <button
                type="button"
                class="nw-color-thumb js-color-swatch is-selected"
                data-color-id=""              {# => aucune couleur, mode "produit" #}
                data-color-name=""
                aria-label="{{ product.name }}"
                title="{{ product.name }}"
              >
                <img
                  src="{{ mainSrc }}"
                  alt="{{ product.name }}"
                >
              </button>

              {# 2) Swatches pour chaque couleur #}
              {% for color in product.colors %}

                {# Cherche l'image isMain=true de cette couleur pour la miniature #}
                {% set coverImg = null %}
                {% for image in product.productImages %}
                  {% if image.color and image.color.id == color.id and image.isMain %}
                    {% set coverImg = image %}
                  {% endif %}
                {% endfor %}

                <button
                  type="button"
                  class="nw-color-thumb js-color-swatch"
                  data-color-id="{{ color.id }}"
                  data-color-name="{{ color.name }}"
                  aria-label="{{ color.name }}"
                  title="{{ color.name }}"
                >
                  {% if coverImg %}
                    <img
                      src="{{ asset('uploads/images/products/' ~ coverImg.path) }}"
                      alt="{{ color.name }}"
                    >
                  {% else %}
                    <span
                      class="nw-swatch-hex"
                      style="background-color: {{ color.hexCode }};"
                      title="{{ color.name }} (pas d'image)"
                    ></span>
                  {% endif %}
                </button>

              {% endfor %}

            </div>
          </div>
      {% endif %}

      {# Tailles #}
      {% if allSizes is defined and allSizes|length > 0 %}
      <div class="mb-3">
        <div class="nw-opt-label">Size</div>

        <input
          type="hidden"
          name="size_id"
          class="js-size-input"
          value=""
        >

        <div class="d-flex flex-wrap gap-2" id="sizePills">
          {% for size in allSizes|sort((a, b) => a.position <=> b.position) %}
            <button
              type="button"
              class="nw-pill js-size-pill"
              data-size-id="{{ size.id }}"
            >
              {{ size.label }}
            </button>
          {% endfor %}
        </div>
      </div>
      {#   <div class="nw-divider"></div> #}
    {% endif %}

    {# Quantité + Add to Cart #}
    <form
        action="{{ path('cart.add', { slug: product.slug }) }}"
        method="post"
        class="d-flex align-items-center gap-3 mt-3"
      >
        <div class="nw-qty" role="group" aria-label="Quantity">
          <button class="nw-qty-btn" type="button" onclick="changeQty(-1)" aria-label="Decrease">−</button>
          <span class="nw-qty-val" id="qtyVal">1</span>
          <button class="nw-qty-btn" type="button" onclick="changeQty(1)" aria-label="Increase">+</button>
          <input type="hidden" name="quantity" id="qtyInput" value="1">
        </div>

         {#   Ces deux champs sont remplis par le JS quand l'utilisateur choisit couleur/taille -#}
        <input type="hidden" name="variant_id" id="cartVariantId" value="">
        <input type="hidden" name="size_id"    id="cartSizeId"    value="">

        <button type="submit" class="nw-btn nw-btn-primary flex-grow-1">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.2">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          Add to Cart
        </button>
      </form>
    </div>
    
    {# Variantes par couleur #}
    <script id="colorVariantsData" type="application/json">
      {{ colorVariants|json_encode|raw }}
    </script>

    <script>
      window.baseProductData = {
        price: {{ product.price }},
        compareAtPrice: {{ product.compareAtPrice is not null ? product.compareAtPrice : 'null' }},
        stock: {{ product.stock }},
        // facultatif ici : toutes les tailles -> on peut lister les IDs
        sizeIds: [
          {% for size in allSizes %}
            {{ size.id }}{% if not loop.last %}, {% endif %}
          {% endfor %}
        ]
      };
    </script>
</section>

  {# ════════════════════════════════════════════
     TABS
  ════════════════════════════════════════════ #}
  <div class="nw-tabs mb-4">
    <nav class="d-flex">
      <button class="nw-tab" data-tab="details">Product Details</button>
      <button class="nw-tab active" data-tab="reviews">Rating &amp; Reviews</button>
      <button class="nw-tab" data-tab="faq">FAQs</button>
    </nav>
  </div>

  {# ── TAB: Product Details ── #}
  <div id="tab-details" class="tab-pane d-none">
    <div class="row">
      <div class="col-lg-8">
        <h3 class="fw-bold mb-3" style="font-family:var(--nw-font-display)">Product Details</h3>
        <p class="nw-desc mb-3">{{ product.description }}</p>
        {# Tu pourras ajouter ici une liste de caractéristiques si tu ajoutes un champ dédié #}
      </div>
    </div>
  </div>

  {# ── TAB: Reviews ── #}
  <div id="tab-reviews" class="tab-pane">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
      <h2 class="mb-0 fs-5 fw-bold" style="font-family:var(--nw-font-display)">
        All Reviews <span class="text-muted fw-normal">({{ reviews|length }})</span>
      </h2>
      <div class="d-flex align-items-center gap-2">
        <button class="nw-kebab border rounded-pill px-3" style="width:auto;height:40px;" aria-label="Filter">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 6h16M7 12h10M10 18h4" stroke="#111" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <select class="form-select form-select-sm rounded-pill" style="height:40px;border-color:var(--nw-line);font-size:13px;box-shadow:none;" aria-label="Sort reviews">
          <option>Latest</option>
          <option>Top Rated</option>
          <option>Oldest</option>
        </select>
        {# Bouton Write a Review — visible seulement si connecté #}
        {% if app.user %}
          <button class="nw-btn nw-btn-outline" data-bs-toggle="modal" data-bs-target="#reviewModal">
            Write a Review
          </button>
        {% else %}
          <a href="{{ path('app_login') }}" class="nw-btn nw-btn-outline">
            Login to Write a Review
          </a>
        {% endif %}
      </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-3" id="reviewGrid">
      {% for review in reviews|slice(0, 6) %}
        <div class="col review-item">
          <article class="nw-reviewcard h-100">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="nw-stars" style="font-size:14px;">
                {% for i in 1..5 %}
                  <span {% if i > review.rating %}class="nw-star-dim"{% endif %}>★</span>
                {% endfor %}
              </span>
              <button class="nw-kebab" aria-label="Options">···</button>
            </div>
            <div class="d-flex align-items-center gap-2 mb-2">
              <strong style="font-size:14px;">{{ review.authorName }}</strong>
              <span class="nw-verified" title="Verified purchase">✓</span>
            </div>
            <p class="nw-review-text mb-2">"{{ review.comment }}"</p>
            <div class="nw-review-date">
              Posted on {{ review.createdAt|date('F d, Y') }}
            </div>
          </article>
        </div>
      {% else %}
        <div class="col-12">
          <p class="text-muted text-center py-5">Be the first to review this product!</p>
        </div>
      {% endfor %}
    </div>

    {% if reviews|length > 6 %}
      <div class="text-center mt-4">
        <button class="nw-btn nw-btn-outline" id="loadMoreBtn" data-page="1" data-product="{{ product.id }}">
          Load More Reviews
        </button>
      </div>
    {% endif %}
  </div>

