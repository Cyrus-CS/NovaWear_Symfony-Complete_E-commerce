{% extends 'base.html.twig' %}

{% block title %}Coupon index{% endblock %}

{% block body %}
<div class="container py-4">
    <h1>Coupon index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Code</th>
                <th>Description</th>
                <th>DiscountType</th>
                <th>DiscountValue</th>
                <th>StartsAt</th>
                <th>ExpiresAt</th>
                <th>IsActive</th>
                <th>MinCartTotal</th>
                <th>MaxUses</th>
                <th>UsedCount</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for coupon in coupons %}
            <tr>
                <td>{{ coupon.id }}</td>
                <td>{{ coupon.code }}</td>
                <td>{{ coupon.description }}</td>
                <td>{{ coupon.discountType }}</td>
                <td>{{ coupon.discountValue }}</td>
                <td>{{ coupon.startsAt ? coupon.startsAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ coupon.expiresAt ? coupon.expiresAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ coupon.isActive ? 'Yes' : 'No' }}</td>
                <td>{{ coupon.minCartTotal }}</td>
                <td>{{ coupon.maxUses }}</td>
                <td>{{ coupon.usedCount }}</td>
                <td>
                    <a href="{{ path('app_coupon_show', {'id': coupon.id}) }}">show</a>
                    <a href="{{ path('app_coupon_edit', {'id': coupon.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="12">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_coupon_new') }}">Create new</a>
</div>
{% endblock %}
