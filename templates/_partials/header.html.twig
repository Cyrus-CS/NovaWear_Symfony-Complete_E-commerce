{# ── TOPBAR ─────────────────────────────────────────────────── #}
<div class="bg-dark text-white py-2" id="nw-topbar">
  <div class="container d-flex align-items-center justify-content-center position-relative">
    <p class="mb-0 small">
      Sign up and get 20% off to your first order.
      <a href="{{ path('app_register') }}" class="text-white fw-semibold">Sign Up Now</a>
    </p>
    <button
      type="button"
      class="btn-close btn-close-white position-absolute end-0"
      style="font-size:.7rem;"
      aria-label="Close"
      onclick="this.closest('#nw-topbar').remove()"
    ></button>
  </div>
</div>

{# ── HEADER ──────────────────────────────────────────────────── #}
<header class="bg-white border-bottom sticky-top">
  <div class="container">
    <nav class="navbar navbar-expand-lg px-0 py-3">

      {# Logo #}
      <a class="navbar-brand fw-black fs-4 text-dark me-4" href="{{ path('home') }}"
         style="font-weight:900;letter-spacing:.5px;">
        SHOP.CO
      </a>

      {# Toggle mobile #}
      <button class="navbar-toggler border-0" type="button"
              data-bs-toggle="collapse" data-bs-target="#mainNav"
              aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="mainNav">

        {# Nav links #}
        <ul class="navbar-nav me-3 mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link text-dark fw-medium" href="{{ path('shop.index') }}">Shop</a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-dark fw-medium" href="#">On Sale</a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-dark fw-medium" href="{{ path('contact') }}">Contact us</a>
          </li>
        </ul>

        {# Search #}
        <div class="input-group me-3 flex-grow-1" style="max-width:420px;">
          <span class="input-group-text bg-light border-0 rounded-start-pill ps-3">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" stroke="#777" stroke-width="2"/>
              <path d="M16.5 16.5 21 21" stroke="#777" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
          <input type="search"
                 class="form-control bg-light border-0 rounded-end-pill"
                 placeholder="Search for products…"
                 style="box-shadow:none;" />
        </div>

        {# Icons #}
        <div class="d-flex align-items-center gap-2 ms-auto">

          {# Cart #}
          <a href="{{ path('cart.index') }}"
             class="btn btn-light btn-sm rounded-circle p-2 d-flex align-items-center justify-content-center"
             style="width:38px;height:38px;" aria-label="Cart">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M6 7h15l-2 10H8L6 7Z" stroke="#111" stroke-width="2"/>
              <path d="M6 7 5 3H2" stroke="#111" stroke-width="2" stroke-linecap="round"/>
              <circle cx="9"  cy="21" r="1" fill="#111"/>
              <circle cx="18" cy="21" r="1" fill="#111"/>
            </svg>
          </a>

          {# Wishlist #}
          {% if app.user %}
            <a href="{{ path('account.wishlist') }}"
          {% else %}
            <a href="{{ path('app_login') }}"
          {% endif %}
             class="btn btn-light btn-sm rounded-circle p-2 d-flex align-items-center justify-content-center"
             style="width:38px;height:38px;" aria-label="Wishlist">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="#111" stroke-width="2"/>
            </svg>
          </a>

          {# Account dropdown #}
          <div class="dropdown">
            <button
              class="btn btn-light btn-sm d-flex align-items-center gap-2 rounded-pill px-3"
              style="height:38px;font-size:.85rem;"
              type="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              {# Icône profil #}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" stroke="#111" stroke-width="2"/>
                <path d="M4 21a8 8 0 0 1 16 0"              stroke="#111" stroke-width="2" stroke-linecap="round"/>
              </svg>

              {% if app.user %}
                <span class="d-none d-md-inline text-dark">
                  Hello, <strong>{{ app.user.username }}</strong>
                </span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                  <path d="M6 9l6 6 6-6" stroke="#555" stroke-width="2" stroke-linecap="round"/>
                </svg>
              {% endif %}
            </button>

            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 rounded-3 py-2"
                style="min-width:210px;">
              {% if app.user %}
                {# En-tête avec nom + email #}
                <li class="px-3 py-2">
                  <div class="fw-bold text-dark" style="font-size:.875rem;">
                    {{ app.user.username }}
                  </div>
                  <div class="text-muted" style="font-size:.75rem;word-break:break-all;">
                    {{ app.user.email }}
                  </div>
                </li>
                <li><hr class="dropdown-divider my-1"></li>
                <li>
                  <a class="dropdown-item py-2" href="{{ path('account.dashboard') }}">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="me-2" style="vertical-align:middle;">
                      <rect x="3" y="3" width="7" height="7" rx="1" stroke="#555" stroke-width="1.8"/>
                      <rect x="14" y="3" width="7" height="7" rx="1" stroke="#555" stroke-width="1.8"/>
                      <rect x="3" y="14" width="7" height="7" rx="1" stroke="#555" stroke-width="1.8"/>
                      <rect x="14" y="14" width="7" height="7" rx="1" stroke="#555" stroke-width="1.8"/>
                    </svg>
                    Dashboard
                  </a>
                </li>
                <li>
                  <a class="dropdown-item py-2" href="{{ path('account.orders') }}">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="me-2" style="vertical-align:middle;">
                      <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="#555" stroke-width="1.8"/>
                      <rect x="9" y="3" width="6" height="4" rx="1" stroke="#555" stroke-width="1.8"/>
                    </svg>
                    Orders
                  </a>
                </li>
                <li>
                  <a class="dropdown-item py-2" href="{{ path('account.addresses') }}">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="me-2" style="vertical-align:middle;">
                      <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z" stroke="#555" stroke-width="1.8"/>
                      <circle cx="12" cy="10" r="3" stroke="#555" stroke-width="1.8"/>
                    </svg>
                    Addresses
                  </a>
                </li>
                <li>
                  <a class="dropdown-item py-2" href="{{ path('account.details') }}">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="me-2" style="vertical-align:middle;">
                      <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="#555" stroke-width="1.8"/>
                      <circle cx="12" cy="7" r="4" stroke="#555" stroke-width="1.8"/>
                    </svg>
                    Account details
                  </a>
                </li>
                <li>
                  <a class="dropdown-item py-2" href="{{ path('account.wishlist') }}">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="me-2" style="vertical-align:middle;">
                      <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" stroke="#555" stroke-width="1.8"/>
                    </svg>
                    Wishlist
                  </a>
                </li>
                <li><hr class="dropdown-divider my-1"></li>
                <li>
                  <a class="dropdown-item py-2 text-danger" href="{{ path('app_logout') }}">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="me-2" style="vertical-align:middle;">
                      <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" stroke="#dc3545" stroke-width="1.8"/>
                      <polyline points="16 17 21 12 16 7" stroke="#dc3545" stroke-width="1.8"/>
                      <line x1="21" y1="12" x2="9" y2="12" stroke="#dc3545" stroke-width="1.8"/>
                    </svg>
                    Logout
                  </a>
                </li>
              {% else %}
                <li>
                  <a class="dropdown-item py-2 fw-semibold" href="{{ path('app_login') }}">
                    Login
                  </a>
                </li>
                <li>
                  <a class="dropdown-item py-2" href="{{ path('app_register') }}">
                    Create account
                  </a>
                </li>
              {% endif %}
            </ul>
          </div>

        </div>{# /icons #}
      </div>{# /collapse #}
    </nav>
  </div>
</header>